# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATEFORGE — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file and rename it to: .env
# 2. Replace each value below with your real keys from stripe.com/dashboard
# 3. NEVER share your .env file or commit it to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# Found in: Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret
# Leave this blank until you set up your webhook on Railway
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Port (Railway sets this automatically — you don't need to change this)
PORT=3456
